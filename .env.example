WEAVER_SNOWFLAKE_ACCOUNT=<your_account>
WEAVER_SNOWFLAKE_USER=<your_user>
WEAVER_SNOWFLAKE_PASSWORD=<your_password>
WEAVER_SNOWFLAKE_ROLE=ACCOUNTADMIN
WEAVER_SNOWFLAKE_WAREHOUSE=COMPUTE_WH

# Workspace database and schema (created by --setup, used by TruLens for evaluation logs)
WEAVER_SNOWFLAKE_DATABASE=semantic_model_weaver
WEAVER_SNOWFLAKE_SCHEMA=trulens

# Your outbound IP for Snowflake network policy (find with: curl -s https://checkip.amazonaws.com)
# Leave unset to skip network policy setup.
WEAVER_ALLOWED_IP=<your_ip>
