FORGE_SNOWFLAKE_ACCOUNT=<your_account>
FORGE_SNOWFLAKE_USER=<your_user>
FORGE_SNOWFLAKE_PASSWORD=<your_password>
FORGE_SNOWFLAKE_ROLE=ACCOUNTADMIN
FORGE_SNOWFLAKE_WAREHOUSE=COMPUTE_WH

# Workspace database and schema (created by --setup, used by TruLens for evaluation logs)
FORGE_SNOWFLAKE_DATABASE=semantic_model_forge
FORGE_SNOWFLAKE_SCHEMA=trulens

# Your outbound IP for Snowflake network policy (find with: curl -s https://checkip.amazonaws.com)
# Leave unset to skip network policy setup.
FORGE_ALLOWED_IP=<your_ip>
